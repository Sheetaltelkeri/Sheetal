02.Movie Rental store system

// 1. Insert 5 movies
db.movies.insertMany([
  {movie_id:1, title:"Movie1", director:"Dir1", genre:"Horror", release_year:2020, rental_price:120, copies_available:5, rating:7.5},
  {movie_id:2, title:"Movie2", director:"Dir2", genre:"Comedy", release_year:2018, rental_price:200, copies_available:3, rating:8.2},
  {movie_id:3, title:"Movie3", director:"Dir3", genre:"Action", release_year:2022, rental_price:140, copies_available:0, rating:6.9},
  {movie_id:4, title:"Movie4", director:"Dir4", genre:"Horror", release_year:2019, rental_price:100, copies_available:2, rating:7.8},
  {movie_id:5, title:"Movie5", director:"Dir5", genre:"Drama", release_year:2021, rental_price:160, copies_available:4, rating:9.0}
])

// 2. Find condition
db.movies.find({rental_price: {$lt:150}, copies_available: {$gt:0}})

