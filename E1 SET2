04.Banking Transaction System

// 1. Insert transactions
db.transactions.insertMany([
  {transaction_id:1, account_holder:"A", account_type:"Savings", transaction_type:"Deposit", amount:60000, transaction_date:new Date("2024-01-01"), branch:"B1", balance_after_transaction:100000},
  {transaction_id:2, account_holder:"A", account_type:"Savings", transaction_type:"Withdrawal", amount:70000, transaction_date:new Date("2024-02-01"), branch:"B1", balance_after_transaction:30000},
  {transaction_id:3, account_holder:"B", account_type:"Current", transaction_type:"Deposit", amount:20000, transaction_date:new Date("2022-01-01"), branch:"B2", balance_after_transaction:50000},
  {transaction_id:4, account_holder:"C", account_type:"Savings", transaction_type:"Withdrawal", amount:80, transaction_date:new Date("2022-01-01"), branch:"B3", balance_after_transaction:1000},
  {transaction_id:5, account_holder:"B", account_type:"Current", transaction_type:"Transfer", amount:50000, transaction_date:new Date("2025-01-01"), branch:"B2", balance_after_transaction:100000}
])

// 2. Aggregation total deposit & withdrawal
db.transactions.aggregate([
  {
    $group:{
      _id:"$account_holder",
      total_deposit:{
        $sum:{
          $cond:[{$eq:["$transaction_type","Deposit"]},"$amount",0]
        }
      },
      total_withdrawal:{
        $sum:{
          $cond:[{$eq:["$transaction_type","Withdrawal"]},"$amount",0]
        }
      }
    }
  }
])

// 3. Flag withdrawals > 50000
db.transactions.updateMany(
  {transaction_type:"Withdrawal", amount:{$gt:50000}},
  {$set:{flagged_for_review:true}}
)

// 4. Delete old small transactions
db.transactions.deleteMany({
  transaction_date:{$lt:new Date("2023-01-01")},
  amount:{$lt:100}
})

// 5. Top 3 branches
db.transactions.aggregate([
  {$group:{_id:"$branch", total:{$sum:"$amount"}}},
  {$sort:{total:-1}},
  {$limit:3}
])

05.Social Media Post Analytics

// 1. Insert posts
db.posts.insertMany([
  {post_id:1, user_name:"user1", content:"Post1", hashtags:["#fun","#tech"], likes_count:100, shares_count:20, comments_count:10, is_verified_user:true, post_date:new Date()},
  {post_id:2, user_name:"user2", content:"Post2", hashtags:["#food","#fun"], likes_count:50, shares_count:10, comments_count:5, is_verified_user:false, post_date:new Date()},
  {post_id:3, user_name:"user3", content:"Post3", hashtags:["#travel"], likes_count:200, shares_count:50, comments_count:30, is_verified_user:true, post_date:new Date()},
  {post_id:4, user_name:"user1", content:"Post4", hashtags:["#tech"], likes_count:80, shares_count:15, comments_count:8, is_verified_user:true, post_date:new Date()},
  {post_id:5, user_name:"user4", content:"Post5", hashtags:["#food","#travel"], likes_count:60, shares_count:12, comments_count:6, is_verified_user:false, post_date:new Date()}
])

// 2. Create multikey index
db.posts.createIndex({hashtags:1})

// 3. Avg likes per hashtag
db.posts.aggregate([
  {$unwind:"$hashtags"},
  {
    $group:{
      _id:"$hashtags",
      avg_likes:{$avg:"$likes_count"}
    }
  }
])

// 4. Add priority_boost
db.posts.updateMany(
  {is_verified_user:true},
  {$set:{priority_boost:true}}
)

// 5. Top 3 users by engagement
db.posts.aggregate([
  {
    $project:{
      user_name:1,
      total_engagement:{
        $add:["$likes_count","$shares_count","$comments_count"]
      }
    }
  },
  {$group:{_id:"$user_name", engagement:{$sum:"$total_engagement"}}},
  {$sort:{engagement:-1}},
  {$limit:3}
])



